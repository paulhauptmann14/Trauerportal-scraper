# Town to watch for within Landkreis Regen
TARGET_CITY=YOUR_TOWN

# How many days to look back at most if a run was missed
LOOKBACK_DAYS=14

# Which channel to notify through: "telegram" or "email"
NOTIFICATION_CHANNEL=telegram

# Telegram bot (used when NOTIFICATION_CHANNEL=telegram)
# 1. Create a new bot with @BotFather in Telegram -> copy the bot token
# 2. Message the bot (e.g. /start), then find your own chat ID, e.g. via
#    https://api.telegram.org/bot<TOKEN>/getUpdates or the @userinfobot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Email/SMTP (used when NOTIFICATION_CHANNEL=email)
# Example for iCloud Mail: create an app-specific password at
# appleid.apple.com -> Sign-In and Security -> App-Specific Passwords
SMTP_HOST=smtp.mail.me.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
NOTIFY_EMAIL_TO=
